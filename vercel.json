{
  "builds": [
    {
      "src": "api/puzzle.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "logicgrid/**" }
    },
    {
      "src": "api/hint.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "logicgrid/**" }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/puzzle", "dest": "/api/puzzle.py" },
    { "src": "/api/hint", "dest": "/api/hint.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/guide", "dest": "/public/guide.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
